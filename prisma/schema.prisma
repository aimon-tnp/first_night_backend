generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Gender {
  male
  female
}

enum Personality {
  introvert
  extrovert
  ambivert
}

enum AgePreference {
  same
  younger
  older
  no_preference
}

enum RegistrationStatus {
  pending
  confirmed
  refunded
}
enum Role {
  USER
  ADMIN
}

model AppConfig {
  key   String @id
  value String

  @@map("app_config")
}

model Profile {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  name      String
  nickname  String
  gender    Gender
  birthday  DateTime @db.Date
  telephone String
  instagram String?

  university String
  faculty    String
  uniYear    Int    @map("uni_year")
  email      String @unique

  emergencyName         String? @map("emergency_name")
  emergencyRelationship String? @map("emergency_relationship")
  emergencyTelephone    String? @map("emergency_telephone")
  allergies             String?
  medications           String?

  // Authentication (store salted+hashed password only)
  username     String @unique @db.Text
  passwordHash String @map("password_hash") @db.Text
  role         Role   @default(USER)

  avatarUrl String @map("avatar_url")

  isMatched Boolean @default(false) @map("is_matched")

  preferences Preferences? @relation("ProfilePreferences") // needs to be nullable to allow creating profile before preferences

  registrations Booking[]
  matchAsMale   Match?         @relation("MaleMatch") // needs to be nullable to allow creating profile before matching
  matchAsFemale Match?         @relation("FemaleMatch")

  @@map("profiles")
}

model Preferences {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  profileId String  @unique @map("profile_id") @db.Uuid
  profile   Profile @relation("ProfilePreferences", fields: [profileId], references: [id], onDelete: Cascade)

  quote         String?

  personality           Personality
  personalityPreference Personality @map("personality_preference")

  agePreference AgePreference @map("age_preference")

  loveLangExpress String @map("love_lang_express")
  loveLangReceive String @map("love_lang_receive")

  hobbies String[]

  fashionStyle      String[] @map("fashion_style")
  fashionPreference String[] @map("fashion_preference")

  characteristics           String[] @map("characteristics")
  characteristicPreference  String[] @map("characteristic_preference")

  @@map("preferences")
}

model Booking { // TO BE REVISED - required activity pics (will this activity be present in future sessions as well?)
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  userId String  @map("user_id") @db.Uuid
  user   Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  sessionId String @default("feb_2026") @map("session_id") // TO BE REVISED
  // Still not final, waiting for decision on how to collect past sessions data
  status    RegistrationStatus @default(pending)

  // Payment Data (nullable until provided)
  amount       Decimal  @db.Decimal(10, 2)
  transferDate DateTime @map("transfer_date") @db.Date
  transferTime DateTime @map("transfer_time") @db.Time
  slipUrl      String   @map("slip_url") // receipt/proof of transfer image URL

  // Refund Data
  refundBankName    String @map("refund_bank_name")
  refundBankNumber  String @map("refund_bank_number")
  refundAccountName String @map("refund_account_name")

  @@unique([userId, sessionId])
  @@map("bookings")
}

model Match {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  maleId String  @unique @map("male_id") @db.Uuid
  male   Profile @relation("MaleMatch", fields: [maleId], references: [id])

  femaleId String  @unique @map("female_id") @db.Uuid
  female   Profile @relation("FemaleMatch", fields: [femaleId], references: [id])

  compatibilityScore Float? @map("compatibility_score")

  @@map("matches")
}
