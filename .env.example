# PostgreSQL (Supabase)
DATABASE_URL="postgresql://..."
DIRECT_URL="postgresql://..."

# Supabase
SUPABASE_URL="https://<project>.supabase.co"
SUPABASE_KEY="<anon-or-service-role-key>"

# JWT
JWT_SECRET="<change-me-to-a-long-random-string>"
JWT_EXPIRES_IN="7d"

# Redis
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_PASSWORD=""
REDIS_DB="0"
REDIS_TLS="false"

# Server
PORT=3000
